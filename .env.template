# ─────────────────────────────────────────────────────────────────────────────
# kdev environment config
# Copy this to .env and fill in your values.
# Only ONE backend section needs to be active at a time.
# ─────────────────────────────────────────────────────────────────────────────


# ── LOCAL OLLAMA (recommended for Linux) ─────────────────────────────────────
# Run a local LLM via Ollama. No cloud, no costs, no rate limits.
# Install Ollama: https://ollama.com
# Pull model:     ollama pull qwen3:27b
#
# If Ollama runs on THIS machine:
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:27b
#
# If Ollama runs on a different LAN machine:
# OLLAMA_BASE_URL=http://192.168.1.X:11434
# OLLAMA_MODEL=qwen3:27b


# ── AWS BEDROCK (comment out if not using) ────────────────────────────────────
# Used on Windows with Atlassian SSO bearer token.
# The bearer token expires — check before use.
#
# AWS_BEARER_TOKEN_BEDROCK=<paste token here>
# AWS_REGION=us-east-1
# ANTHROPIC_DEFAULT_SONNET_MODEL=us.anthropic.claude-sonnet-4-6


# ── DIRECT ANTHROPIC API (comment out if not using) ──────────────────────────
# Fallback if neither Ollama nor Bedrock is available.
# Get key at: https://console.anthropic.com
#
# ANTHROPIC_API_KEY=sk-ant-...


# ── GITHUB MCP (optional) ─────────────────────────────────────────────────────
# Enables GitHub tools (read repos, PRs, issues) via MCP.
# Requires Node.js + npx. Get a PAT at: https://github.com/settings/tokens
# Scopes needed: repo, read:org
#
# GITHUB_TOKEN=ghp_...


# ── DEBUG ─────────────────────────────────────────────────────────────────────
# Set to 1 to enable verbose logging (API calls, tool traces, MCP messages).
# Leave commented out for normal use.
#
# KDEV_DEBUG=1
